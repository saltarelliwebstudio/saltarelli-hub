# Supabase – use the service role key (not anon key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenPhone
OPENPHONE_API_KEY=your-openphone-api-key
OPENPHONE_FROM_NUMBER=+1XXXXXXXXXX

# Server port (optional, defaults to 3099)
PORT=3099
NODE_ENV=production
